MARA_MODE=backtest              # backtest | paper | live
MARA_LIVE=false

# Free — register at fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_key_here

# Ollama (local, no cost)
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=phi3:mini          # phi3:mini on Pi | llama3:8b on laptop

# ACLED (register with institution email)
ACLED_EMAIL=your@email.com
ACLED_PASSWORD=yourpassword

# UCDP GED conflict events — free, email ucdp.uu.se to request token
UCDP_API_TOKEN=

# AIS chokepoint vessel traffic monitor — free account at aisstream.io
AISSTREAM_API_KEY=

# NASA FIRMS thermal anomaly satellite data — free Earthdata account at firms.modaps.eosdis.nasa.gov
NASA_FIRMS_API_KEY=

# Polymarket wallet (needed for execution, not for signal reading)
POLY_PRIVATE_KEY=
POLY_PROXY_WALLET=

# IBKR — Phase 3 only
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# Arbitrader exchanges (added to workers/arbitrader/application.yaml, not here)
# Crypto public REST — no keys needed for data
BINANCE_REST=https://fapi.binance.com
BYBIT_REST=https://api.bybit.com

# Nautilus strategy router
ACTIVE_STRATEGY=auto       # auto (ADX-routed) | swing | range

# Nautilus range_mean_revert strategy tuning (defaults shown)
RANGE_BB_PERIOD=20
RANGE_BB_STD=2.0
RANGE_RSI_PERIOD=14
RANGE_STOP_LOSS_PCT=0.015
RANGE_TAKE_PROFIT_RATIO=1.5

# SEC EDGAR filing monitor — no API key required; SEC only asks for identification
EDGAR_USER_AGENT=MARA-Trading-System your@email.com  # replace with your real email

# Grafana admin password (default: mara_local when unset)
GRAFANA_PASSWORD=          # set before deploying — change from default